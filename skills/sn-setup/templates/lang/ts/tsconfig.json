{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "declaration": true,
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "mcp_server/**/*.ts", "tests/**/*.ts", ".claude/hooks/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
