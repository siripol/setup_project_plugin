{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(make:*)",
      "Bash(ant:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go build:*)",
      "Bash(go mod tidy:*)",
      "Bash(uv sync:*)",
      "Bash(uv run:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(npm install:*)",
      "Bash(npm test:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vitest:*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse":       [{"matcher": ".*", "command": ".claude/hooks/audit.sh"}],
    "PostToolUse":      [{"matcher": ".*", "command": ".claude/hooks/audit.sh"}],
    "UserPromptSubmit": [{"command": ".claude/hooks/audit.sh"}],
    "SessionStart":     [{"command": ".claude/hooks/audit.sh"}],
    "SessionEnd":       [{"command": ".claude/hooks/audit.sh"}],
    "Stop":             [{"command": ".claude/hooks/audit.sh"}]
  },
  "env": {},
  "setting_sources": ["project", "user"]
}
