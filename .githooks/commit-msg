#!/usr/bin/env bash
# In-repo commit-msg hook for setup_project_plugin itself.
#
# Normalization passes (idempotent, runs on every commit):
#   1. Strip any "Co-Authored-By: ...Claude..." trailer line. Explicit char
#      classes keep the match case-insensitive on both BSD sed (darwin) and
#      GNU sed (Linux CI) without relying on the GNU-only `I` flag.
#   2. Append `Author: Siripol <siripoln.media@gmail.com>` as a trailer if
#      that exact identity is not already present. Match on the full identity
#      so a contributor can still add `Author: Someone Else <...>` lines
#      without us clobbering them.
#
# This repo does NOT enforce REQ-id subjects (that constraint belongs to
# downstream scaffolded projects via the sn-setup template variant).
#
# Activate per clone: `git config core.hooksPath .githooks`.

set -eu

msg_file="${1:?commit-msg hook requires the message file}"

sed -i.bak -E '/^[Cc]o-[Aa]uthored-[Bb]y:.*[Cc][Ll][Aa][Uu][Dd][Ee]/d' "$msg_file" && rm -f "$msg_file.bak"

if ! grep -qE '^Author: Siripol <siripoln\.media@gmail\.com>' "$msg_file"; then
    [ -n "$(tail -1 "$msg_file")" ] && printf '\n' >> "$msg_file"
    printf 'Author: Siripol <siripoln.media@gmail.com>\n' >> "$msg_file"
fi

exit 0
